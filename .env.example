# ── Supabase (self-hosted) ───────────────────────────────────────────────
# Point at your self-hosted Supabase instance (behind Caddy).
NEXT_PUBLIC_SUPABASE_URL=https://supabase.yourdomain.com
# Newer Supabase publishable key (sb_publishable_…). Client-side, safe to expose.
# Legacy projects: use NEXT_PUBLIC_SUPABASE_ANON_KEY instead — the app accepts either.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Server-only secret key (sb_secret_…). Used by the intake pipeline / n8n to write
# unlinked data (bypasses RLS). NEVER expose to the client. (Legacy: service_role key.)
SUPABASE_SECRET_KEY=sb_secret_xxx

# ── Auth ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false

# ── AI assistant (chatbot / Savannah) — Step 3 ───────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key

# ── Channels (intake pipeline) — Step 4 ──────────────────────────────────
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
# Sending number for OTP / SMS (E.164). Temporary shared number for now;
# swap to the dedicated EasyCaseload number later — config change only.
TELNYX_FROM_NUMBER=+13252034927
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_SIGNING_KEY=

# ── n8n (thin: outbound sends + scheduled reminders) ─────────────────────
N8N_WEBHOOK_BASE_URL=https://n8nfor516.online
